{
  "name": "@ssm/storage",
  "version": "1.0.0",
  "description": "存储模块 - 支持IndexedDB和localStorage的存储管理",
  "type": "module",
  "main": "./dist/storage.umd.cjs",
  "module": "./dist/storage.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/storage.js",
      "require": "./dist/storage.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest",
    "clean": "rm -rf dist"
  }
}
